# Cloudflare API Token
# Create one at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions:
#   Zone:Zone:Read
#   Zone:Analytics:Read
#   Zone:DNS:Read           (only required for `--backup` / "Backup Zones to Azure")
CLOUDFLARE_API_TOKEN=your_token_here

# Azure Blob Storage for DNS zone backups (optional — only required for backup feature)
# Get the connection string from Azure Portal -> Storage Account -> Access keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# Container name for backups (created automatically if it doesn't exist)
AZURE_STORAGE_CONTAINER=cloudflare-zone-backups
